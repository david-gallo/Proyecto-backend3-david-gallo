{
  "name": "adoptme-backend",
  "version": "1.0.0",
  "description": "API REST para sistema de adopción de mascotas con Express, MongoDB y Swagger",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "mocha test/**/*.test.js --timeout 10000",
    "test:adoptions": "mocha test/adoptions.test.js --timeout 10000",
    "test:users": "mocha test/users.test.js --timeout 10000",
    "test:pets": "mocha test/pets.test.js --timeout 10000",
    "docker:build": "docker build -t adoptme-backend .",
    "docker:run": "docker-compose up -d"
  },
  "keywords": [
    "api",
    "rest",
    "express",
    "mongodb",
    "mongoose",
    "swagger",
    "pets",
    "adoption",
    "docker"
  ],
  "author": "David",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/tu-usuario/adoptme-backend"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "bcrypt": "^5.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^6.7.5",
    "multer": "^1.4.5-lts.1",
    "supertest": "^6.3.3",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "chai": "^4.3.7",
    "mocha": "^10.1.0"
  }
}
