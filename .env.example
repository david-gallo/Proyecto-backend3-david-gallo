# Configuración del servidor
PORT=8080
NODE_ENV=development

# Conexión a MongoDB
# Para desarrollo local:
MONGO_URL=mongodb://localhost:27017/adoptme

# Para Docker Compose:
# MONGO_URL=mongodb://admin:password123@mongodb:27017/adoptme?authSource=admin

# Para MongoDB Atlas:
# MONGO_URL=mongodb+srv://usuario:password@cluster.mongodb.net/adoptme?retryWrites=true&w=majority

# CORS (origen permitido)
# Para desarrollo local con frontend en el puerto 3000:
CORS_ORIGIN=http://localhost:3000
# Para permitir todos los orígenes (solo desarrollo):
# CORS_ORIGIN=*

# JWT Secret (si se implementa autenticación con JWT)
# JWT_SECRET=tu-secreto-super-seguro

# Cookie Secret
# COOKIE_SECRET=tu-cookie-secret
